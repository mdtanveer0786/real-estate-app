# ════════════════════════════════════════════════════════════════════
# EstateElite Backend — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ════════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production        # 'production' enables secure cookies + strict CORS

# ── Database ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/realestate?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────────────
# IMPORTANT: Use strong, random 32+ character secrets. Never reuse them.
JWT_SECRET=<random-32-char-string>
JWT_REFRESH_SECRET=<different-random-32-char-string>
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ── Frontend URL ─────────────────────────────────────────────────────
# Must match EXACTLY your Vercel deployment URL (no trailing slash).
# Used for CORS allowlist and password-reset email links.
FRONTEND_URL=https://real-estateelite.vercel.app

# ── Email (Gmail + App Password) ─────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx    # 16-char App Password from Google Account
# Do NOT put outer quotes around EMAIL_FROM — the value contains < >
EMAIL_FROM=EstateElite Team <your-gmail@gmail.com>
ADMIN_EMAIL=your-gmail@gmail.com

# ── Cloudinary ────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Razorpay (optional — payment works in mock mode without these) ────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ── OpenAI (optional — chatbot falls back to rule-based without this) ─
# OPENAI_API_KEY=sk-...

# ── Google OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_CALLBACK_URL=https://your-backend.onrender.com/api/auth/google/callback
