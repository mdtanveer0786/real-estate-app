{
    "env": {
        "node": true,
        "es2022": true,
        "commonjs": true
    },
    "extends": ["eslint:recommended"],
    "parserOptions": {
        "ecmaVersion": "latest"
    },
    "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
        "no-console": ["warn", { "allow": ["info", "warn", "error"] }],
        "no-process-exit": "off",
        "prefer-const": "error",
        "no-var": "error",
        "eqeqeq": ["error", "always"],
        "curly": ["error", "multi-line"],
        "no-throw-literal": "error",
        "no-return-await": "warn",
        "require-await": "warn"
    },
    "ignorePatterns": ["node_modules/", "logs/", "tests/"]
}
