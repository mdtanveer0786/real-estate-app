# ════════════════════════════════════════════════════════════════════
# EstateElite Frontend — Environment Variables
# Copy this to .env (local) or set in Vercel dashboard.
# ════════════════════════════════════════════════════════════════════

# Backend API URL — NO trailing slash
# Local dev:
VITE_API_URL=http://localhost:5000
# Production (Render backend):
# VITE_API_URL=https://real-estate-app-qjbd.onrender.com

# Razorpay publishable key (safe to expose in frontend)
VITE_RAZORPAY_KEY_ID=rzp_test_...

# Google Analytics (optional)
# VITE_GA_ID=G-XXXXXXXXXX

# Google Maps (optional)
# VITE_GOOGLE_MAPS_API_KEY=...

# Site URL for SEO meta tags
VITE_APP_URL=https://real-estateelite.vercel.app
